#!/usr/bin/env -S php -dphar.readonly=0
<?php declare(strict_types=1);

/*
 * Collapse a phar_builder exploded module tree into a single PHAR payload and
 * rewrite generated wrappers to execute that PHAR.
 *
 * Usage:
 *   bin/package-phar-payload build/share/modules/manticore-buddy \
 *     build/manticore-buddy build/manticore-buddy.sh build/manticore-buddy.ps1
 */

if ($argc < 2) {
	error('Usage: ' . basename(__FILE__) . ' /path/to/module-dir [wrapper ...]');
}

$moduleDir = realpath($argv[1]);
if ($moduleDir === false || !is_dir($moduleDir)) {
	error('Module directory does not exist: ' . $argv[1]);
}

$package = basename($moduleDir);
$mainFile = $moduleDir . DIRECTORY_SEPARATOR . 'src' . DIRECTORY_SEPARATOR . 'main.php';
$autoloadFile = $moduleDir . DIRECTORY_SEPARATOR . 'vendor' . DIRECTORY_SEPARATOR . 'autoload.php';
if (!is_file($mainFile)) {
	error("Cannot find module entrypoint: $mainFile");
}
if (!is_file($autoloadFile)) {
	error("Cannot find Composer autoloader: $autoloadFile");
}

$pharName = $package . '.phar';
$pharPath = $moduleDir . DIRECTORY_SEPARATOR . $pharName;
$tmpPharPath = $moduleDir . DIRECTORY_SEPARATOR . '.' . $package . '.tmp.phar';
@unlink($tmpPharPath);
@unlink($pharPath);

$phar = new Phar($tmpPharPath);
$phar->startBuffering();
$phar->setSignatureAlgorithm(Phar::SHA256);

$iterator = new RecursiveIteratorIterator(
	new RecursiveCallbackFilterIterator(
		new RecursiveDirectoryIterator($moduleDir, FilesystemIterator::SKIP_DOTS),
		static function (SplFileInfo $file) use ($pharName): bool {
			$name = $file->getFilename();
			if ($name === $pharName || str_ends_with($name, '.tmp.phar')) {
				return false;
			}
			return true;
		}
	)
);
$phar->buildFromIterator($iterator, $moduleDir);
$phar->setStub("#!/usr/bin/env php\n<?php\nPhar::mapPhar('$pharName');\nrequire 'phar://$pharName/src/main.php';\n__HALT_COMPILER();\n");
$phar->stopBuffering();
chmod($tmpPharPath, 0755);
rename($tmpPharPath, $pharPath);

foreach (new DirectoryIterator($moduleDir) as $entry) {
	if ($entry->isDot() || $entry->getFilename() === $pharName) {
		continue;
	}
	removePath($entry->getPathname());
}

writeSearchdCompatibilityEntrypoint($moduleDir, $pharName);

for ($i = 2; $i < $argc; ++$i) {
	rewriteWrapper($argv[$i], $pharName);
}

echo "Packaged $package as $pharPath" . PHP_EOL;

function writeSearchdCompatibilityEntrypoint(string $moduleDir, string $pharName): void {
	$srcDir = $moduleDir . DIRECTORY_SEPARATOR . 'src';
	if (!is_dir($srcDir) && !mkdir($srcDir, 0755, true)) {
		error("Failed to create compatibility src directory: $srcDir");
	}
	$entrypoint = $srcDir . DIRECTORY_SEPARATOR . 'main.php';
	$content = <<<'PHP'
<?php declare(strict_types=1);

/*
 * Compatibility entrypoint for Manticore Search Buddy auto-discovery.
 * searchd looks for manticore-buddy/src/main.php, while the actual packaged
 * Buddy payload lives in ../manticore-buddy.phar to keep package file counts low.
 */

$phar = dirname(__DIR__) . DIRECTORY_SEPARATOR . 'manticore-buddy.phar';
if (!is_file($phar)) {
	fwrite(STDERR, "Manticore Buddy PHAR not found: {$phar}" . PHP_EOL);
	exit(1);
}

require 'phar://' . $phar . '/src/main.php';
PHP;
	if (file_put_contents($entrypoint, $content) === false) {
		error("Failed to write compatibility entrypoint: $entrypoint");
	}
}

function rewriteWrapper(string $path, string $pharName): void {
	if (!is_file($path)) {
		return;
	}
	$content = file_get_contents($path);
	if ($content === false) {
		error("Failed to read wrapper: $path");
	}

	$updated = str_replace(
		[
			'elif [ -d "$SCRIPT_DIR/../src/main.php" ]; then' . "\n" . '  src_dir="$SCRIPT_DIR/.."',
			'"$src_dir/src/main.php"',
			'"$srcDir\\src\\main.php"',
		],
		[
			'elif [ -f "$SCRIPT_DIR/../' . $pharName . '" ]; then' . "\n" . '  src_dir="$SCRIPT_DIR/.."',
			'"$src_dir/' . $pharName . '"',
			'"$srcDir\\' . $pharName . '"',
		],
		$content
	);

	if ($updated === $content) {
		error("Wrapper did not contain a known src/main.php pattern, refusing to package broken PHAR wrapper: $path");
	}
	if (file_put_contents($path, $updated) === false) {
		error("Failed to rewrite wrapper: $path");
	}
	echo "Rewrote wrapper $path to launch $pharName" . PHP_EOL;
}

function removePath(string $path): void {
	if (is_dir($path) && !is_link($path)) {
		$items = new RecursiveIteratorIterator(
			new RecursiveDirectoryIterator($path, FilesystemIterator::SKIP_DOTS),
			RecursiveIteratorIterator::CHILD_FIRST
		);
		foreach ($items as $item) {
			$itemPath = $item->getPathname();
			if ($item->isDir() && !$item->isLink()) {
				rmdir($itemPath);
			} else {
				unlink($itemPath);
			}
		}
		rmdir($path);
		return;
	}
	unlink($path);
}

function error(string $message): never {
	fwrite(STDERR, $message . PHP_EOL);
	exit(1);
}
